{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "target": "ESNext",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",

    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"],

      // ✅ actions는 app 바깥(실구현)을 최우선으로
      "@/actions/*": ["./actions/*", "./app/actions/*"],
      "@/app/actions/*": ["./actions/*"],

      // ✅ 단일 타입 소스 고정
      "@/types/*": ["./types/*"],
      // ✅ 컴포넌트/라이브러리 공용 경로
      "@/components/*": ["./components/*", "./app/components/*"],
      "@/lib/*": ["./lib/*", "./app/lib/*"],
      "@/hooks/*": ["./hooks/*", "./app/hooks/*", "./app/(protected)/_hooks/*"],

      // (필요 시) app 전체 별칭
      "@/app/*": ["./app/*"]
    },

    "types": ["node"],
    "incremental": true,
    "forceConsistentCasingInFileNames": true,

    "plugins": [{ "name": "next" }]
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": [
    "node_modules",
    ".next",
    "dist",
    "_archive/**",
    "app/(protected)/listening/test/_*.tsx"
  ]
}
