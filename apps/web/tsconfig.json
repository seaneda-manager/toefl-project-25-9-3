{
  "compilerOptions": {
    "forceConsistentCasingInFileNames": true,
    "ignoreDeprecations": "5.0",
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./*"
      ],
      "@/app/*": [
        "./app/*"
      ],
      "@/components/*": [
        "./components/*"
      ],
      "@ui/*": [
        "./components/ui/*"
      ],
      "@test/*": [
        "./components/test/*"
      ],
      "@reading/*": [
        "./components/reading/*"
      ],
      "@listening/*": [
        "./components/listening/*"
      ],
      "@dashboard/*": [
        "./components/dashboard/*"
      ],
      "@/lib/*": [
        "./lib/*"
      ],
      "@/styles/*": [
        "./styles/*"
      ],
      "@/types/*": [
        "./app/types/*"
      ],
      "@/actions/*": [
        "./actions/*"
      ],
      "@/models/reading": [
        "./models/reading"
      ],
      "@/models/reading/*": [
        "./models/reading/*"
      ],
      "@/models/*": [
        "./models/*"
      ],
      "@internal-types/*": [
        "../../packages/types/src/*"
      ]
    },
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": false,
    "noEmit": true,
    "incremental": true,
    "module": "esnext",
    "esModuleInterop": true,
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "next-env.d.ts",
    ".next/types/**/*.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
