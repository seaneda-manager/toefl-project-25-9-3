{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"],
      "@/app/*": ["./app/*"],
      "@/components/*": ["./components/*"],
      "@ui/*": ["./components/ui/*"],
      "@test/*": ["./components/test/*"],
      "@reading/*": ["./components/reading/*"],
      "@listening/*": ["./components/listening/*"],
      "@dashboard/*": ["./components/dashboard/*"],
      "@/lib/*": ["./lib/*"],
      "@/styles/*": ["./styles/*"],
      // ✅ 타입(웹 전용 + 공용)
      "@/types/*": ["./app/types/*"],
      "@types/*": ["../../packages/types/src/*"],

      // ✅ 추가: 앱 내부 SSOT 모델 경로
      "@/models/*": ["./models/*"],
      // ✅ 추가: Reading은 반드시 여기서만 import
      "@/models/reading": ["./models/reading/index.ts"]
    },
    "allowJs": true,
    "incremental": true,
    "jsx": "preserve",
    "plugins": [{ "name": "next" }]
  },
  "include": ["./**/*.ts", "./**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
