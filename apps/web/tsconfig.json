{
  "compilerOptions": {
    "target": "ESNext",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"],
      "@/app/*": ["./app/*"],
      "@/types/*": ["./app/types/*"],
      "@/actions/*": ["./actions/*", "./app/actions/*"],
      "@/components/*": ["./components/*", "./app/components/*"],
      "@/lib/*": ["./lib/*", "./app/lib/*"],
      "@/hooks/*": ["./hooks/*", "./app/hooks/*", "./app/(protected)/_hooks/*"]
    },
    "types": ["node"],
    "incremental": true,
    "forceConsistentCasingInFileNames": true,
    "plugins": [{ "name": "next" }]
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": ["node_modules"]
}
