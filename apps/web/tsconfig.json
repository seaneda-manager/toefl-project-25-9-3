{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "target": "ESNext",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./*"
      ],
      // ✅ actions는 app 바깥(실구현)을 최우선으로
      "@/actions/*": [
        "./actions/*",
        "./app/actions/*"
      ],
      "@/app/actions/*": [
        "./actions/*"
      ],
      // 아래는 실제 디렉터리 우선 → app 하위 폴백
      "@/types/*": [
        "./types/*",
        "./app/types/*"
      ],
      "@/components/*": [
        "./components/*",
        "./app/components/*"
      ],
      "@/lib/*": [
        "./lib/*",
        "./app/lib/*"
      ],
      "@/hooks/*": [
        "./hooks/*",
        "./app/hooks/*",
        "./app/(protected)/_hooks/*"
      ],
      // (선택) app 전체 alias가 필요하면 유지
      "@/app/*": [
        "./app/*"
      ]
    },
    "types": [
      "node"
    ],
    "incremental": true,
    "forceConsistentCasingInFileNames": true,
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    ".next",
    "dist",
    "app/(protected)/listening/test/_*.tsx"
  ]
}
