{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./*"
      ],
      "@/app/*": [
        "./app/*"
      ],
      "@/components/*": [
        "./components/*"
      ],
      "@ui/*": [
        "./components/ui/*"
      ],
      "@test/*": [
        "./components/test/*"
      ],
      "@reading/*": [
        "./components/reading/*"
      ],
      "@listening/*": [
        "./components/listening/*"
      ],
      "@dashboard/*": [
        "./components/dashboard/*"
      ],
      "@/lib/*": [
        "./lib/*"
      ],
      "@/styles/*": [
        "./styles/*"
      ],
      "@/types/*": [
        "./app/types/*"
      ],
      /* --- SSOT: reading --- */
      "@/models/reading": [
        "./models/reading/index.ts"
      ],
      "@/models/*": [
        "./models/*"
      ],
      /* (있다면) 내부 패키지 타입 */
      "@internal-types/*": [
        "../../packages/types/src/*"
      ]
    },
    "plugins": [
      {
        "name": "next"
      }
    ],
    "jsx": "preserve",
    "lib": [
      "ES2021",
      "DOM",
      "DOM.Iterable"
    ],
    "moduleResolution": "bundler",
    "types": [
      "node",
      "react",
      "react-dom"
    ],
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "allowJs": true,
    "incremental": true,
    "skipLibCheck": true,
    "noEmit": true
    /* 선택: 루트에서 strict 꺼져 있으면 아래 주석 해제
    "strict": true
    */
  },
  "include": [
    "next-env.d.ts",
    "./**/*.ts",
    "./**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "**/.eslintrc.cjs",
    "**/postcss.config.*",
    "**/tailwind.config.*",
    "**/next.config.*",
    "node_modules",
    ".next",
    "dist"
  ]
}