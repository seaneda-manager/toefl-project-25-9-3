# 백업
Copy-Item .\apps\web\package.json .\apps\web\package.json.bak -ErrorAction SilentlyContinue

# 정상 package.json으로 덮어쓰기 (UTF-8, BOM 없음)
@"
{
  "name": "web",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3002",
    "build": "next build",
    "start": "next start -p 3002",
    "lint": "next lint --max-warnings=0",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@plasmicapp/loader-nextjs": "^1.0.441",
    "@supabase/ssr": "^0.7.0",
    "next": "^15.5.4",
    "posthog-js": "^1.272.0",
    "react": "18.2.0",
    "react-dom": "18.2.0"
  },
  "devDependencies": {
    "@sentry/nextjs": "^10.17.0"
  },
  "engines": { "node": ">=18.18" },
  "packageManager": "pnpm@9.12.3"
}
"@ | ForEach-Object {
    [System.IO.File]::WriteAllText("apps\web\package.json", $_, (New-Object System.Text.UTF8Encoding($false)))
}
